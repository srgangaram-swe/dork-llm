# Strict by default: auto resolves a compatible local artifact and does not
# silently fall back to the deterministic demo provider.
DORK_MODEL_PROVIDER=auto
DORK_MODEL_PATH=
DORK_MODEL_DEVICE=auto
DORK_DEMO_MODE=false

DORK_RAG_CONFIG=configs/rag_default.yaml
DORK_MAX_MESSAGES=24
DORK_MAX_MESSAGE_CHARS=8000
DORK_MAX_TOTAL_MESSAGE_CHARS=24000
DORK_MAX_NEW_TOKENS=512
DORK_GENERATION_TIMEOUT_SECONDS=120
